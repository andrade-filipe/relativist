# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Cargo lock (library convention — include if binary, exclude if library)
# Relativist is a binary, so Cargo.lock SHOULD be committed.
# Uncomment if this becomes a library:
# Cargo.lock

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.vim/

# OS files
Thumbs.db
Desktop.ini
.DS_Store
._*

# Environment / Secrets
.env
.env.*
!.env.example

# Coverage and profiling
*.profraw
*.profdata
lcov.info
tarpaulin-report.html
coverage/

# Benchmarks output (raw data, not the spec)
criterion/
flamegraph.svg
perf.data
perf.data.old

# Ad-hoc / exploratory benchmark results (frozen baselines stay in results/locked/)
results/smoke/
results/*.bak
results/*.before_*
results/*.pre_*

# Generic backup snapshots
*.bak
*.before_*
*.pre_*

# Python bytecode (scripts/ helpers)
__pycache__/
*.pyc

# Temporary data files (test inputs/outputs)
/data/
/*.bin

# Run logs and LaTeX/tooling logs (never tracked)
/logs/
*.log

# Ad-hoc result outputs at repo root (frozen evidence lives in reproduce_article/)
/results/

# Fresh reproduction runs (the frozen reference under results/locked/ stays tracked)
/reproduce_article/results/reproduction/

# RPI disposable working artifacts (RESEARCH.md / PLAN.md, regenerated each cycle)
/docs/rpi/

# Docker
.docker/

# Claude Code local settings (not shared)
.claude/settings.local.json
