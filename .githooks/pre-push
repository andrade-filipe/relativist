#!/usr/bin/env bash
# Pre-push gate — mirrors the REQUIRED CI gate (ci.yml) locally so failures are
# caught BEFORE they reach GitHub and turn a PR red. This is the essential tier
# only (fmt + clippy + library unit tests); the optional integration suite runs
# via `cargo test` / extended-tests.yml. See docs/TESTING.md.
#
# Enable once per clone:
#     git config core.hooksPath .githooks
#
# Emergency bypass (discouraged — CI will still enforce it):
#     git push --no-verify
set -euo pipefail

echo "[pre-push] cargo fmt --check"
cargo fmt --check

echo "[pre-push] cargo clippy --all-targets --all-features -- -D warnings"
cargo clippy --all-targets --all-features -- -D warnings

echo "[pre-push] cargo test --lib"
cargo test --lib

echo "[pre-push] essential gate OK"
