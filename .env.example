# Relativist — Docker Compose environment variables
#
# Copy this file to `.env` and tune as needed:
#   cp .env.example .env
# Docker Compose auto-loads `.env` from the project root.
#
# To run an ad-hoc bench without committing values, prefer `-e` on the CLI:
#   docker compose --profile bench-tcp run --rm \
#     -e CHUNK_SIZE=10000 -e BENCH_WORKERS=2,4,8 bench-tcp

# ---------------------------------------------------------------------------
# Default profile (coordinator + worker; v1-style)
# ---------------------------------------------------------------------------

# Number of worker replicas (also passed to coordinator --workers).
NUM_WORKERS=2

# ---------------------------------------------------------------------------
# bench-tcp profile (streaming bench runner)
# ---------------------------------------------------------------------------

# Streaming chunk size. Set to a small value (e.g. 100) to exercise multi-batch
# assembly; set to 10000+ to mirror the local rodada baseline.
CHUNK_SIZE=10000

# SPEC-21 R37c — generation backpressure window (rounds).
MAX_PENDING_LIFETIME=16

# SPEC-22 R10b — recycle policy. One of:
#   disable-under-delta   (default; safe — matches local baseline)
#   border-clean          (aggressive; reclaims early but stricter invariants)
RECYCLE_POLICY=disable-under-delta

# Net representation. One of:
#   dense    (default; matches v1 baseline — `Net`)
#   sparse   (SparseNet construction-time micro-bench, single-worker only)
REPRESENTATION=dense

# Benchmark inputs forwarded to `bench --sizes` and `--workers`.
# Use comma-separated lists; the bench harness sweeps the cartesian product.
BENCH_SIZES=1000
BENCH_WORKERS=2,4,8

# Benchmark execution mode. One of:
#   local           (in-process; no TCP — fastest, used for smoke)
#   tcp_localhost   (default; spins coordinator + workers via TCP loopback)
BENCH_MODE=tcp_localhost
